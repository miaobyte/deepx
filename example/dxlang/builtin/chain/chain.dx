def native_chain(A:int, B:int, C:int) -> (D:int) {
    print("A =", A)
    print("B =", B)
    print("C =", C)
    './tmp' <- A + B
    print("tmp =", './tmp')
    './tmp' * C -> './D'
    print("D =", './D')
}

str.set("deepxctlrun") -> './term'

# Top-level call: native_chain(2, 3, 4) -> './out'
native_chain(2, 3, 4) -> './out'

def print_chain(A:int, B:int, C:int) -> (D:int) {
    print("A =", A)
    A + B -> './tmp'
    print("tmp =", './tmp')
    print("C =", C)
    './tmp' * C -> './D'
    print("D =", './D')
}

str.set("deepxctlrun") -> './term'

# Top-level call: print_chain(2, 3, 4) -> './out'
print_chain(2, 3, 4) -> './out'

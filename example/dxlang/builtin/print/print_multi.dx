def print_multi(A:int, B:int, C:int) -> (R:int) {
    print("A =", A)
    print("B =", B)
    print("C =", C)
    A + B -> './t'
    print("t =", './t')
    './t' + C -> './R'
    print("R =", './R')
}

str.set("deepxctlrun") -> './term'

# Top-level call: print_multi(1, 2, 3) -> './out'
print_multi(1, 2, 3) -> './out'

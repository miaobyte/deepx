# three_add: add three numbers — demonstrates multi-read (3 inputs → 1 output)
def three_add(A:int, B:int, C:int) -> (R:int) {
    print("A =", A)
    print("B =", B)
    A + B -> './t'
    print("t =", './t')
    print("C =", C)
    './t' + C -> './R'
    print("R =", './R')
}

str.set("deepxctlrun") -> './term'

# Top-level call: three_add(2, 3, 4) -> './out'
three_add(2, 3, 4) -> './out'

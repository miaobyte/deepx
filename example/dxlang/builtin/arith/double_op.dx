def double_op(A:int, B:int) -> (S:int, D:int) {
    print("A =", A)
    print("B =", B)
    A + B -> './S'
    print("S =", './S')
    A - B -> './D'
    print("D =", './D')
}

str.set("deepxctlrun") -> './term'

# Top-level call: double_op(10, 3) -> ('./sum', './diff')
double_op(10, 3) -> ('./sum', './diff')
